# Porta da API
PORT=4000

# URL(s) do frontend permitidas para CORS (separar por vírgula em produção)
# Exemplo: https://main.dxxxx.amplifyapp.com,https://www.seudominio.com
FRONTEND_URL=http://localhost:3000

# String de conexão do Postgres
# Em produção ela é obrigatória.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/criptoinvest

# Segredo para assinatura dos tokens JWT
JWT_SECRET=change-me-to-a-long-random-secret

# OAuth Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=your-redirect-uri

# AWS SES
AWS_REGION=us-east-1
SES_FROM_EMAIL=no-reply@example.com
S3_BUCKET_NAME=your-s3-bucket-name
REGISTER_CODE_EXPIRES_MINUTES=15
REGISTER_CODE_MAX_ATTEMPTS=5
PASSWORD_RESET_EXPIRES_MINUTES=30
